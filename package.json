{
  "name": "vx-engine",
  "version": "1.0.55",
  "description": "A modern, scalable Express.js boilerplate with authentication, user management, and admin features",
  "main": "app.js",
  "scripts": {
    "start": "cross-env node app.js",
    "dev": "cross-env NODE_ENV=development node app.js",
    "production": "cross-env NODE_ENV=production node app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node scripts/seed.js",
    "backup": "node scripts/backup.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "keywords": [
    "express",
    "nodejs",
    "mongodb",
    "boilerplate",
    "jwt",
    "authentication",
    "api",
    "rest"
  ],
  "author": "Ishwar Sarade <ishwar.sarade@gmail.com> (https://ishwar.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyIshwar/vx-engine.git"
  },
  "bugs": {
    "url": "https://github.com/heyIshwar/vx-engine/issues"
  },
  "homepage": "https://github.com/heyIshwar/vx-engine#readme",
  "dependencies": {
    "aws-sdk": "^2.1691.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "dotenv-safe": "^9.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-errors": "^2.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.0",
    "morgan": "^1.10.0",
    "nconf": "^0.12.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
